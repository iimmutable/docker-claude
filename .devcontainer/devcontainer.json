{
  "name": "Claude Code Dev Environment",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "claude-dev",
  "workspaceFolder": "/workspace",

  // Run as the dev user
  "remoteUser": "dev",

  // Features to install inside the container
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "username": "dev"
    }
  },

  // VS Code settings inside the container
  "customizations": {
    "vscode": {
      "settings": {
        // Terminal
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.cwd": "/workspace",

        // Editor
        "editor.formatOnSave": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": true,
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,

        // TypeScript / JavaScript
        "typescript.preferences.importModuleSpecifier": "relative",
        "javascript.preferences.importModuleSpecifier": "relative",

        // .NET
        "dotnet.server.useOmnisharp": false,
        "omnisharp.enableRoslynAnalyzers": true,

        // Go
        "go.toolsManagement.autoUpdate": true,
        "go.useLanguageServer": true,

        // Rust
        "rust-analyzer.check.command": "clippy",

        // Docker
        "docker.environment": {
          "DOCKER_HOST": "unix:///var/run/docker.sock"
        }
      },

      // Extensions to install
      "extensions": [
        // ---- Core ----
        "ms-azuretools.vscode-docker",
        "github.copilot",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "gruntfuggly.todo-tree",
        "streetsidesoftware.code-spell-checker",

        // ---- JavaScript / TypeScript ----
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",

        // ---- React ----
        "dsznajder.es7-react-js-snippets",

        // ---- Vue ----
        "Vue.volar",

        // ---- .NET / C# ----
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",

        // ---- Go ----
        "golang.go",

        // ---- Rust ----
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",

        // ---- Solana / Blockchain ----
        "nicholasgcoles.solidity",
        "JuanBlanco.solidity",

        // ---- Flutter / Dart ----
        "Dart-Code.dart-code",
        "Dart-Code.flutter",

        // ---- Mobile ----
        "nickmillerdev.react-native-tools-preview",

        // ---- Data / Config ----
        "redhat.vscode-yaml",
        "ms-python.python"
      ]
    }
  },

  // Ports to auto-forward
  "forwardPorts": [
    3000,   // React / Express
    5000,   // ASP.NET HTTP
    5001,   // ASP.NET HTTPS
    5173,   // Vite
    8080,   // Go / Generic
    8081,   // Vue / Metro
    8899,   // Solana validator
    19000,  // Expo
    19001   // Expo DevTools
  ],

  "portsAttributes": {
    "3000": { "label": "React / Express", "onAutoForward": "notify" },
    "5000": { "label": "ASP.NET HTTP", "onAutoForward": "notify" },
    "5001": { "label": "ASP.NET HTTPS", "onAutoForward": "notify" },
    "5173": { "label": "Vite Dev Server", "onAutoForward": "notify" },
    "8080": { "label": "Go / Generic", "onAutoForward": "notify" },
    "8081": { "label": "Vue / Metro Bundler", "onAutoForward": "notify" },
    "8899": { "label": "Solana Validator", "onAutoForward": "ignore" },
    "19000": { "label": "Expo", "onAutoForward": "ignore" },
    "19001": { "label": "Expo DevTools", "onAutoForward": "ignore" }
  },

  // Environment variables
  "remoteEnv": {
    "NVM_DIR": "/usr/local/nvm",
    "GOPATH": "/home/dev/go",
    "GOROOT": "/usr/local/go",
    "DOTNET_ROOT": "/usr/local/dotnet",
    "RUSTUP_HOME": "/usr/local/rustup",
    "CARGO_HOME": "/usr/local/cargo",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },

  // Run after container starts
  "postStartCommand": "echo '🚀 Claude Code Dev Environment ready!' && . /usr/local/nvm/nvm.sh 2>/dev/null || true",

  // Lifecycle
  "shutdownAction": "stopCompose"
}
